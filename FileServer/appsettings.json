{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "FileServer.Services.FileConflictService": "Debug"
    }
  },
  "AllowedHosts": "*",
  "FileServerConfig": {
    "RootPath": "E:\\FileServer",
    "PhotoIndexDirectories": [ "data/图片" ],
    "AudioIndexDirectory": "data/音乐",
    "VideoLibraryDirectory": "data/影视",
    "ThumbnailDirectory": "系统文件/thumbnails",
    "MetadataDirectory": "系统文件/metadata",
    "CoversDirectory": "系统文件/covers",
    // 新增：音频元数据库路径
    "AudioLiteDbPath": "系统文件/audio-metadata.db",
    // 新增：图片元数据库路径
    "PhotoLiteDbPath": "系统文件/photo-metadata.db",
    // 以下为原有配置（保留，以防其他地方引用，但新服务将使用上面的独立配置）
    "LiteDbPath": "系统文件/audio-metadata.db",
    "LyricsMappingFile": "系统文件/lyrics-mappings.json",
    "SongMetadataMappingFile": "系统文件/song-metadata-mappings.json",
    "HttpPort": 8080,
    "HttpsPort": 8081,
    "QuicPort": 8082,
    "MaxFileSize": 10737418240,
    "EnableQuic": true,
    "CertificatePath": "",
    "CertificatePassword": "",
    "FFmpegPath": "C:\\FFMPEG\\ffmpeg\\bin\\ffmpeg.exe",
    "FFprobePath": "C:\\FFMPEG\\ffmpeg\\bin\\ffprobe.exe",
    "ThumbnailWidth": 320,
    "ThumbnailHeight": 180,
    "ThumbnailFormat": "jpg",
    "MaxConcurrentThumbnailWorkers": 4,
    "ThumbnailPositionPercentage": 50,
    "ConflictResolution": {
      "Strategy": "AddCounter",
      "CounterFormat": " ({0})",
      "MaxAttempts": 1000,
      "EnableLogging": true,
      "KeepOriginalExtension": true,
      "SkipEmptyFiles": true,
      "MaxFilenameLength": 255,
      "GenerateBackup": false,
      "BackupDirectory": ".backups",
      "KeepBackupDays": 30
    }
  },
  "Preview": {
    "CharactersPerPage": 6000
  }
}