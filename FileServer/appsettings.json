{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "FileServer.Services.FileConflictService": "Debug"
    }
  },
  "AllowedHosts": "*",
  "FileServerConfig": {
    "RootPath": "E:\\FileServer",
    "HttpPort": 8080,
    "HttpsPort": 8081,
    "QuicPort": 8082,
    "MaxFileSize": 10737418240,
    "EnableQuic": true,
    "CertificatePath": "",
    "CertificatePassword": "",
    "FFmpegPath": "C:\\FFMPEG\\ffmpeg\\bin\\ffmpeg.exe",
    "FFprobePath": "C:\\FFMPEG\\ffmpeg\\bin\\ffprobe.exe",
    "ThumbnailWidth": 320,
    "ThumbnailHeight": 180,
    "ThumbnailFormat": "jpg",
    "MaxConcurrentThumbnailWorkers": 4,
    "ThumbnailPositionPercentage": 50,
    "ConflictResolution": {
      "Strategy": "AddCounter",
      "CounterFormat": " ({0})",
      "MaxAttempts": 1000,
      "EnableLogging": true,
      "KeepOriginalExtension": true,
      "SkipEmptyFiles": true,
      "MaxFilenameLength": 255,
      "GenerateBackup": false,
      "BackupDirectory": ".backups",
      "KeepBackupDays": 30
    }
  }
}